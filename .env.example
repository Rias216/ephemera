# Native providers. /connect can also accept these keys at runtime.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# OpenAI-compatible endpoints such as OpenRouter, Groq, Together, or LM Studio.
# The URL and model are stored by /connect; the key remains environment-only.
EPHEMERA_API_KEY=

# Optional. Defaults to http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# Optional semantic-memory embeddings. When unset, Ephemera uses its local
# zero-network hash embedder and never creates embedding API cost.
EPHEMERA_EMBEDDING_URL=
EPHEMERA_EMBEDDING_API_KEY=
EPHEMERA_EMBEDDING_MODEL=text-embedding-3-small

# Optional default metrics enablement. The --metrics flag also enables it.
EPHEMERA_METRICS=

# Optional diagnostics locations. Session bundles contain session.json,
# debug.jsonl, and context.jsonl for every chat session.
EPHEMERA_DEBUG_LOG=
EPHEMERA_SESSION_LOG_DIR=
