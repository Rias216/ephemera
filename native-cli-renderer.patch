-func parseHex(value string) (int, int, int, bool) {
-	value = strings.TrimPrefix(strings.TrimSpace(value), "#")
-	if len(value) != 6 {
-		return 0, 0, 0, false
-	}
-	parsed, err := strconv.ParseUint(value, 16, 24)
-	if err != nil {
-		return 0, 0, 0, false
-	}
-	return int(parsed >> 16), int((parsed >> 8) & 0xff), int(parsed & 0xff), true
-}
