-			index++
-			continue
-		}
-		if strings.HasPrefix(source[index:], "**") || strings.HasPrefix(source[index:], "__") || strings.HasPrefix(source[index:], "~~") {
-			index += 2
-			continue
-		}
-		if strings.ContainsRune("*_`", rune(source[index])) {
-			index++
-			continue
-		}
-		if source[index] == '[' {
